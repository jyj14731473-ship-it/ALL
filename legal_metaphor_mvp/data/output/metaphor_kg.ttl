ex:lemmametaphor_lg116 a ex:MetaphorInstance ;
    ex:hasConceptualMetaphorLabel "ABSTRACT JUDGMENT IS FOLLOWING" ;
    ex:hasConfidence "0.8600" ;
    ex:hasContextSentence "성폭력 범죄는 성별에 따라 차별적으로 구조화된 성을 기반으로 지극히 사적인 영역에서 발생하므로, 피해자라도 본격적으로 문제제기를 하게 되기 전까지는 피해사실이 알려지기를 원하지 아니하고 가해자와 종전의 관계를 계속 유지하는 경우도 적지 아니하며, 피해상황에서도 가해자에 대한 이중적인 감정을 느끼기도 한다." ;
    ex:hasMIPVULabel "MRW_INDIRECT" ;
    ex:hasMetaphorType "STRUCTURAL" ;
    ex:hasSourceDomain ex:sourcedomain_뒤를_따라_가는_물리적_이동 ;
    ex:hasSourceDomainLabel "뒤를 따라 가는 물리적 이동" ;
    ex:hasSurfaceExpression "따르다" ;
    ex:hasTargetDomain ex:targetdomain_판단_행위의_기준화 ;
    ex:hasTargetDomainLabel "판단·행위의 기준화" ;
    ex:realizesConceptualMetaphor ex:conceptualmetaphor_abstract_judgment_is_following .

