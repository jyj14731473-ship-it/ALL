ex:lemmametaphor_lg345 a ex:MetaphorInstance ;
    ex:hasConceptualMetaphorLabel "조사·검증의 산출 IS 열매" ;
    ex:hasConfidence "0.6800" ;
    ex:hasContextSentence "피고인의 신체에 대한 검증 결과에 따르면, 피고인의 가슴은 불룩하여 우람하고, 팔뚝도 굵고 탄탄해 보였으며, 복부와 등에는 약간의 주름이 보였고 피부가 약간 처져 보이긴 하였으나 전체적으로 피고인의 몸은 근육질의 건장한 몸으로 보였고, 피고인의 하반신 피부는 상반신에 비하여 더 매끄럽고 깨끗한 상태로 보였는바, 피해자가 실제로는 피고인의 벗은 몸을 제대로 보지 못한 채 피고인의 연령 등으로만 짐작하여 신체의 주름상태 등을 만연히 진술하였을 가능성을 배제할 수 없다." ;
    ex:hasMIPVULabel "MRW_CANDIDATE" ;
    ex:hasMetaphorType "ONTOLOGICAL" ;
    ex:hasSourceDomain ex:sourcedomain_열매_맺음 ;
    ex:hasSourceDomainLabel "열매/맺음" ;
    ex:hasSurfaceExpression "결과" ;
    ex:hasTargetDomain ex:targetdomain_조사_검증의_산출 ;
    ex:hasTargetDomainLabel "조사·검증의 산출" ;
    ex:realizesConceptualMetaphor ex:conceptualmetaphor_조사_검증의_산출_is_열매 .

